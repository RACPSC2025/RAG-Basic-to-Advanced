# ===========================================
# VARIABLES DE ENTORNO - PRODUCCIÓN
# ===========================================
# Copiar este archivo a .env y llenar los valores
# cp .env.example .env
# ===========================================

# ===========================================
# Google Gemini API
# ===========================================
# Obtener API Key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_api_key_aqui
GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ===========================================
# Qdrant Vector Store
# ===========================================
# URL de Qdrant (local o cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=documentos_legales

# ===========================================
# LangSmith (Observability)
# ===========================================
# Obtener API Key: https://smith.langchain.com/
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=tu_langsmith_api_key
LANGSMITH_PROJECT=legal-rag-production
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ===========================================
# Base de Datos (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/legal_rag
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=legal_rag

# ===========================================
# Redis (Cache)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# Configuración de la Aplicación
# ===========================================
APP_NAME=Legal RAG Agent
APP_VERSION=1.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT=60

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ===========================================
# Seguridad
# ===========================================
# Generar con: openssl rand -hex 32
SECRET_KEY=tu_secret_key_muy_largo_y_seguro_generado_con_openssl
ALLOWED_HOSTS=localhost,127.0.0.1,tudominio.com
CORS_ORIGINS=https://tudominio.com

# API Key para acceder al servicio
API_KEY=tu_api_key_para_clientes

# ===========================================
# Monitoreo
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin

# ===========================================
# LlamaParse (Opcional - Para parsing avanzado)
# ===========================================
LLAMA_PARSE_API_KEY=
LLAMA_PARSE_BASE_URL=https://api.cloud.llamaindex.ai

# ===========================================
# Configuración de RAG
# ===========================================
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=3
RAG_RERANKING=true
RAG_RERANK_TOP_K=2

# ===========================================
# Configuración de LLM
# ===========================================
LLM_MODEL=gemini-2.0-flash-exp
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000
LLM_MAX_RETRIES=3
