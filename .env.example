# ===========================================
# Configuración de la Aplicación
# ===========================================

APP_NAME="Chatbot Legal Básico"
APP_VERSION="1.0.0"
LOG_LEVEL="INFO"

# ===========================================
# Configuración de AWS Bedrock
# ===========================================

# Credenciales de AWS (requeridas)
# Obténlas en: https://console.aws.amazon.com/iam/home#/security_credentials
AWS_ACCESS_KEY_ID="tu_aws_access_key"
AWS_SECRET_ACCESS_KEY="tu_aws_secret_access_key"

# Token de sesión (opcional, solo para credenciales temporales)
AWS_SESSION_TOKEN=""

# Región de AWS donde está disponible Bedrock
AWS_REGION="us-east-2"

# ===========================================
# Configuración del LLM
# ===========================================

# Modelo para chat (Amazon Nova Lite - inference profile)
# Formato: arn:aws:bedrock:{region}:{account-id}:inference-profile/{profile-id}
LLM_MODEL_ID="arn:aws:bedrock:us-east-2:762233737662:inference-profile/us.amazon.nova-lite-v1:0"

# Proveedor del modelo (amazon, anthropic, meta, etc.)
LLM_PROVIDER="amazon"

# Temperatura del modelo (0.0 = determinista, 1.0 = creativo)
# Para legal se recomienda bajo (0.0-0.3)
LLM_TEMPERATURE="0.3"

# Máximo de tokens en la respuesta
LLM_MAX_TOKENS="2048"

# ===========================================
# Configuración de Memoria
# ===========================================

# Número de mensajes a recordar en memoria a corto plazo
MEMORY_SHORT_TERM_K="5"

# Habilitar memoria a largo plazo (resúmenes automáticos)
MEMORY_LONG_TERM_ENABLED="true"

# ===========================================
# Configuración de Human in the Loop
# ===========================================

# Habilitar aprobación humana para respuestas críticas
HITL_ENABLED="true"

# Umbral de confianza para solicitar aprobación (0.0-1.0)
HITL_CONFIDENCE_THRESHOLD="0.7"

# ===========================================
# Rate Limiting (Opcional)
# ===========================================

# Límite de solicitudes por minuto a la API
RATE_LIMIT_REQUESTS_PER_MINUTE="10"

# Límite de ráfaga (burst)
RATE_LIMIT_BURST_LIMIT="3"

# Máximo de reintentos ante errores
MAX_RETRIES="3"
